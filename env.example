# AKIS DevAgents - Environment Configuration Template
# Copy this file to .env.local and fill in your actual values

# ============================================
# GitHub App Configuration (REQUIRED)
# ============================================
# Your GitHub App ID (found in GitHub App settings)
GITHUB_APP_ID=your_github_app_id_here

# GitHub App Private Key (base64 encoded)
# Generate and download from GitHub App settings, then encode:
# cat private-key.pem | base64 | tr -d '\n'
GITHUB_PRIVATE_KEY=your_base64_encoded_private_key_here

# GitHub App Installation ID
# Find this in the URL after installing the app:
# https://github.com/settings/installations/{installation_id}
GITHUB_APP_INSTALLATION_ID=your_installation_id_here

# GitHub App Client ID (for OAuth flow)
GITHUB_APP_CLIENT_ID=your_client_id_here

# GitHub App Client Secret (for OAuth flow)
GITHUB_APP_CLIENT_SECRET=your_client_secret_here

# Webhook secret (if using webhooks)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ============================================
# AI / LLM Configuration (REQUIRED)
# ============================================
# OpenRouter API Key for multi-model AI access
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Default AI model to use (optional, defaults to gpt-4-turbo)
# Examples: gpt-4-turbo, gpt-3.5-turbo, claude-3-opus, etc.
DEFAULT_AI_MODEL=gpt-4-turbo

# ============================================
# Application Configuration (OPTIONAL)
# ============================================
# Next.js environment (development, production, test)
NODE_ENV=development

# Application URL (for OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# ============================================
# Database Configuration (FUTURE)
# ============================================
# Uncomment and configure when database support is added
# DATABASE_URL=postgresql://user:password@localhost:5432/devagents
# DATABASE_POOL_SIZE=10

# ============================================
# Redis/Cache Configuration (FUTURE)
# ============================================
# Uncomment when cache support is added
# REDIS_URL=redis://localhost:6379
# CACHE_TTL=3600

# ============================================
# Security & Rate Limiting (OPTIONAL)
# ============================================
# Session secret for JWT signing (auto-generated if not provided)
# SESSION_SECRET=your_random_session_secret_here

# Rate limit (requests per minute)
RATE_LIMIT=60

# ============================================
# Feature Flags (OPTIONAL)
# ============================================
# Enable/disable experimental features
ENABLE_BETA_FEATURES=false
ENABLE_WEBHOOKS=false
ENABLE_ANALYTICS=false

# ============================================
# Observability (OPTIONAL)
# ============================================
# Sentry DSN for error tracking
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Analytics tracking ID
# ANALYTICS_ID=your_analytics_id_here

# ============================================
# Development Tools (DEVELOPMENT ONLY)
# ============================================
# Enable debug mode (verbose logging)
DEBUG=false

# Mock GitHub API (for testing without real GitHub App)
MOCK_GITHUB_API=false

# ============================================
# Notes
# ============================================
# - Never commit .env.local to version control
# - See docs/ENV_SETUP.md for detailed setup instructions
# - See docs/GITHUB_APP_SETUP.md for GitHub App configuration
# - Restart the dev server after changing environment variables

