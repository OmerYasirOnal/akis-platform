# env.llm.local.example
# Local LLM Configuration for AKIS Platform
# Copy to backend/.env.local and adjust as needed

# ============================================================================
# Local LLM Provider Configuration
# ============================================================================

# Provider: Use 'openai' for LocalAI (OpenAI-compatible)
AI_PROVIDER=openai

# Base URL: Point to local LocalAI instance
AI_BASE_URL=http://localhost:8080/v1

# API Key: LocalAI doesn't require a real key, but client expects one
# Use a dummy value (will be ignored by LocalAI)
AI_API_KEY=local-dummy-key

# ============================================================================
# Model Selection (must match models available in LocalAI)
# ============================================================================

# Default model for worker/generation tasks
# Example: ggml-gpt4all-j or any compatible model you've loaded
AI_MODEL_DEFAULT=ggml-gpt4all-j

# Model for planning tasks (can be same or different)
AI_MODEL_PLANNER=ggml-gpt4all-j

# Model for validation tasks (ideally stronger if available)
AI_MODEL_VALIDATION=ggml-gpt4all-j

# ============================================================================
# Timeout and Retry Configuration (optional)
# ============================================================================

# Local inference can be slower than cloud APIs
# Increase timeout for CPU-based inference
# AI_REQUEST_TIMEOUT_MS=120000

# Max retries for transient failures
# AI_PLANNER_MAX_RETRIES=3

# Base delay between retries (ms)
# AI_RETRY_BASE_DELAY_MS=1000

# ============================================================================
# RAG Configuration (Phase 2)
# ============================================================================

# Qdrant vector database
# RAG_QDRANT_URL=http://localhost:6333

# Embedding model (will be configured in Phase 2)
# RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ============================================================================
# Notes
# ============================================================================
# 1. Download model files separately - see docs/QA_EVIDENCE_LOCAL_LLM_CONTRACT.md
# 2. Place models in ./data/localai/models/ directory
# 3. LocalAI will auto-load models on startup
# 4. Check available models: curl http://localhost:8080/v1/models

