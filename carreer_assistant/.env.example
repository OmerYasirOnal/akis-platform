# ============================================================
# Career Assistant — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env with real secrets.
# ============================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o          # or gpt-5.2 when available

# --- Telegram Notifications ---
TELEGRAM_BOT_TOKEN=           # from @BotFather
TELEGRAM_CHAT_ID=             # your personal chat ID

# --- Upwork API ---
UPWORK_API_KEY=
UPWORK_API_SECRET=
UPWORK_ACCESS_TOKEN=
UPWORK_ACCESS_SECRET=

# --- Freelancer.com API ---
FREELANCER_OAUTH_TOKEN=
FREELANCER_API_URL=https://www.freelancer.com/api

# --- Platform Credentials (for browser automation) ---
FIVERR_EMAIL=
FIVERR_PASSWORD=
BIONLUK_EMAIL=
BIONLUK_PASSWORD=
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# --- Database ---
DATABASE_PATH=./data/career.db

# --- Daily Limits ---
MAX_DISCOVER_PER_DAY=80
MAX_SHORTLIST_PER_DAY=10
MAX_SUBMIT_PER_DAY=5
MAX_OUTREACH_PER_DAY=3

# --- Scoring Thresholds ---
SCORE_APPLY_THRESHOLD=70
SCORE_CONSIDER_THRESHOLD=50

# --- User Profile ---
USER_NAME=Ömer Yasir Önal
USER_ROLE=intern,junior
USER_WORK_MODEL=remote,istanbul_hybrid
USER_SALARY_FLOOR_TRY=50000
USER_LANGUAGES=tr,en
USER_TECH_STACK=typescript,javascript,nodejs,react,fastify,drizzle,postgresql,vite,tailwind
