{
  "name": "@akis/career-assistant",
  "version": "0.1.0",
  "description": "Autonomous career assistant and freelance platform orchestrator",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "career": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts",
    "discover": "tsx src/cli/index.ts discover",
    "score": "tsx src/cli/index.ts score",
    "apply": "tsx src/cli/index.ts apply",
    "status": "tsx src/cli/index.ts status",
    "profile": "tsx src/cli/index.ts profile"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "node-telegram-bot-api": "^0.66.0",
    "openai": "^4.80.0",
    "playwright": "^1.50.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "@types/node-telegram-bot-api": "^0.64.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
