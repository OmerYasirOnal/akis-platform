{
  "name": "akis-backend",
  "version": "0.1.0",
  "description": "AKIS Platform Backend - AI Agent Workflow Engine",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "node --test --import tsx test/**/*.test.ts",
    "test:ci": "NODE_ENV=test node --test --import tsx test/**/*.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "keywords": [
    "ai",
    "agents",
    "workflow"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^8.0.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^2.0.1",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.33.0",
    "fastify": "^4.26.0",
    "fastify-plugin": "^4.5.1",
    "pg": "^8.11.3",
    "prom-client": "^15.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/pg": "^8.10.9",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "drizzle-kit": "^0.22.0",
    "eslint": "^9.39.1",
    "pino-pretty": "^13.1.2",
    "prettier": "^3.2.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.46.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
