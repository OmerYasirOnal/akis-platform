{
  "name": "akis-backend",
  "version": "0.2.0",
  "description": "AKIS Platform Backend — AI Agent Workflow Engine (Fastify + TypeScript + Drizzle ORM)",
  "author": "Ömer Yasir Önal <omeryasironal@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/OmerYasirOnal/akis-platform-devolopment",
    "directory": "devagents/backend"
  },
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "pnpm run test:unit",
    "test:unit": "NODE_ENV=test SKIP_MCP_TESTS=true SKIP_DB_TESTS=true node --test --import dotenv/config --import tsx test/unit/*.test.ts",
    "test:integration": "NODE_ENV=test node --test --import dotenv/config --import tsx test/integration/*.test.ts",
    "test:ci": "NODE_ENV=test SKIP_MCP_TESTS=true node --test --import dotenv/config --import tsx test/unit/*.test.ts test/integration/*.test.ts",
    "test:mcp": "NODE_ENV=test node --test --import dotenv/config --import tsx test/integration/mcp-gateway.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:ci": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "keywords": [
    "ai",
    "agents",
    "workflow"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^8.0.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^2.0.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.22.0",
    "drizzle-orm": "^0.33.0",
    "fastify": "^4.26.0",
    "fastify-plugin": "^4.5.1",
    "jose": "^6.1.1",
    "nodemailer": "^8.0.1",
    "pg": "^8.11.3",
    "pino": "^10.3.1",
    "prom-client": "^15.1.0",
    "rss-parser": "^3.13.0",
    "stripe": "^20.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^20.19.24",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.10.9",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "pino-pretty": "^13.1.2",
    "prettier": "^3.2.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.46.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
