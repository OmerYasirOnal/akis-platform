# AKIS Backend Environment Variables
# Copy this file to .env and configure with your actual values

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Environment mode (development, production, test)
NODE_ENV=development

# Server configuration
AKIS_HOST=0.0.0.0
AKIS_PORT=3000

# URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:5173

# ============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================================================

# Full connection string (required)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/akis_v2

# Individual PostgreSQL settings (optional, used if DATABASE_URL not set)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=akis_v2
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# Cookie configuration for session management
AUTH_COOKIE_NAME=akis_sid
AUTH_COOKIE_MAXAGE=604800
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_SECURE=false
# AUTH_COOKIE_DOMAIN=.example.com

# ============================================================================
# AI SERVICE CONFIGURATION (Optional)
# ============================================================================

# AI provider: 'openrouter', 'openai', or 'mock' (defaults to 'mock' if not set)
AI_PROVIDER=mock
# AI_API_KEY=your-api-key-here

# ============================================================================
# MCP (Model Context Protocol) INTEGRATIONS (Optional)
# ============================================================================

# GitHub MCP Service
# GITHUB_MCP_BASE_URL=https://github-mcp.example.com
# GITHUB_APP_ID=your-github-app-id
# GITHUB_INSTALLATION_ID=your-installation-id
# GITHUB_APP_PRIVATE_KEY_PEM=your-private-key-pem

# Atlassian MCP Service (Jira, Confluence)
# Enable Atlassian integration (set to 'true' to enable, requires all ATLASSIAN_* vars)
MCP_ATLASSIAN_ENABLED=false
# ATLASSIAN_MCP_BASE_URL=https://atlassian-mcp.example.com
# ATLASSIAN_ORG_ID=your-org-id
# ATLASSIAN_API_TOKEN=your-api-token
# ATLASSIAN_EMAIL=your-email@example.com

# ============================================================================
# CI/CD & TESTING NOTES
# ============================================================================
# For CI environments:
# - DATABASE_URL must point to a test database (e.g., postgresql://postgres:postgres@localhost:5432/akis_v2_test)
# - AI_PROVIDER can remain 'mock' (no API key required)
# - MCP integrations are optional (leave disabled for CI)
# - AUTH_COOKIE_SECURE should be 'false' for local/CI testing


NODE_ENV=development
HOST=0.0.0.0
PORT=3000
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DATABASE_URL=postgres://user:pass@localhost:5432/akis

# Session / JWT
AUTH_COOKIE_NAME=akis_session
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_DOMAIN=
AUTH_JWT_SECRET=replace-me-with-32-characters
AUTH_SESSION_TTL_SECONDS=2592000

# GitHub OAuth (user login)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_URL=http://localhost:3000/api/auth/github/callback

# GitHub App (installation tokens for repo operations)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY='-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----'
GITHUB_APP_WEBHOOK_SECRET=

# OpenRouter (AI completions)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_REFERER=https://your-app.example
OPENROUTER_APP_TITLE=AKIS Platform
AI_PRIVACY_EXPERIMENTAL_ALLOWED=false

# Model defaults
AKIS_MODEL_DEFAULT_SCRIBE=deepseek/deepseek-r1:free
AKIS_MODEL_DEFAULT_TRACE=qwen/qwen3-coder:free
AKIS_MODEL_DEFAULT_PROTO=qwen/qwen3-coder:free

