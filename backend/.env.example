# ============================================================
# AKIS Platform — Local Development Environment
# Copy this file to .env and fill in your values
# ============================================================

# --- Application ---
DEV_MODE=true
NODE_ENV=development
PORT=3000
AKIS_HOST=0.0.0.0
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=info
TRUST_PROXY=false
CSRF_ENABLED=false

# --- Database ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=akis_v2
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/akis_v2

# --- Authentication & Session ---
AUTH_JWT_SECRET=<REQUIRED: openssl rand -hex 32>
AUTH_COOKIE_NAME=akis_sid
AUTH_COOKIE_MAXAGE=604800
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=Lax

# --- GitHub (Pipeline — repo oluşturma, push, PR) ---
GITHUB_TOKEN=<REQUIRED: Fine-grained PAT — Contents + PRs + Metadata>
GITHUB_REPOSITORY=omeryasironal/akis-platform-devolopment

# --- OAuth: GitHub (kullanıcı login) ---
GITHUB_OAUTH_CLIENT_ID=<from GitHub Developer Settings → OAuth Apps>
GITHUB_OAUTH_CLIENT_SECRET=<from same>

# --- OAuth: Google (kullanıcı login) ---
GOOGLE_OAUTH_CLIENT_ID=<from Google Cloud Console → Credentials>
GOOGLE_OAUTH_CLIENT_SECRET=<from same>
# NOT: Callback URL'ler .env'de tanımlanmaz.
# Kod FRONTEND_URL'den otomatik üretir: ${FRONTEND_URL}/auth/oauth/${provider}/callback

# --- Email ---
EMAIL_PROVIDER=mock
# EMAIL_PROVIDER=resend için:
# RESEND_API_KEY=re_xxx
# RESEND_FROM_EMAIL=noreply@akisflow.com

# --- AI Service ---
AI_PROVIDER=mock
# AI_PROVIDER=anthropic için:
# ANTHROPIC_API_KEY=sk-ant-xxx
# AI_API_KEY=sk-ant-xxx
AI_MODEL=claude-sonnet-4-6
AI_DETERMINISTIC_MODE=true

# --- AI Key Encryption ---
AI_KEY_ENCRYPTION_KEY=<REQUIRED: openssl rand -hex 32>
AI_KEY_ENCRYPTION_KEY_VERSION=v1

# --- Rate Limiting ---
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW=60000

# --- Feature Flags ---
FEATURE_FLAG_UNSTABLE_ROUTES=false
MCP_ATLASSIAN_ENABLED=false
SCRIBE_DEV_GITHUB_BOOTSTRAP=false
SKIP_MCP_TESTS=true
