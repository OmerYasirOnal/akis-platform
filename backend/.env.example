# ==============================================================================
# AKIS Backend - Environment Variables Example
# ==============================================================================
# Copy this file to .env and fill in the values.
# Required variables are marked with [REQUIRED].
# Optional variables have default values or are only needed for specific features.
# ==============================================================================

# ------------------------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------------------------
NODE_ENV=development
AKIS_HOST=0.0.0.0
AKIS_PORT=3000
LOG_LEVEL=info

# ------------------------------------------------------------------------------
# URLs
# ------------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# CORS Configuration
# Comma-separated list of allowed origins
# ------------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ------------------------------------------------------------------------------
# Database Configuration [REQUIRED]
# PostgreSQL connection string
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/akis_v2

# Individual Postgres settings (used by some tools)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=akis_v2
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ------------------------------------------------------------------------------
# Authentication [REQUIRED]
# ------------------------------------------------------------------------------
# JWT secret - must be at least 32 characters
AUTH_JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars

# Cookie settings
AUTH_COOKIE_NAME=akis_sid
AUTH_COOKIE_MAXAGE=604800
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_DOMAIN=

# ------------------------------------------------------------------------------
# AI Service Configuration
# ------------------------------------------------------------------------------
# Provider: openrouter | openai | mock
# Set to 'mock' for development without real AI calls
AI_PROVIDER=mock

# New-style AI configuration (preferred)
# AI_API_KEY=your-api-key
# AI_BASE_URL=https://openrouter.ai/api/v1
# AI_MODEL_DEFAULT=meta-llama/llama-3.3-70b-instruct:free
# AI_MODEL_PLANNER=meta-llama/llama-3.3-70b-instruct:free
# AI_MODEL_VALIDATION=google/gemini-2.0-flash-exp:free

# Legacy OpenRouter configuration (also supported)
# OPENROUTER_API_KEY=your-openrouter-api-key
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Legacy OpenAI configuration (also supported)
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Note: Legacy OPENROUTER_*/OPENAI_* variables are used as fallbacks
# when AI_* variables are not set. AI_* variables take precedence.

# ------------------------------------------------------------------------------
# GitHub Integration (Optional)
# Required only when using ScribeAgent or ProtoAgent with real repos
# ------------------------------------------------------------------------------
# MCP endpoint base URL
GITHUB_MCP_BASE_URL=

# GitHub App credentials (for production)
GITHUB_APP_ID=
GITHUB_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_PEM=
GITHUB_PRIVATE_KEY_BASE64=

# Personal Access Token (for development)
GITHUB_TOKEN=

# ------------------------------------------------------------------------------
# Atlassian Integration (Jira/Confluence)
# Optional in development, required in production
# ------------------------------------------------------------------------------
# Set to 'true' to enable Atlassian integration in development
MCP_ATLASSIAN_ENABLED=false

# MCP endpoint base URL
ATLASSIAN_MCP_BASE_URL=

# Atlassian credentials (required when MCP_ATLASSIAN_ENABLED=true or NODE_ENV=production)
ATLASSIAN_ORG_ID=
ATLASSIAN_API_TOKEN=
ATLASSIAN_EMAIL=
