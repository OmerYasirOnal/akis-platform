# AKIS Backend Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/akis_v2

# AI Provider (anthropic | openai | openrouter | mock)
AI_PROVIDER=anthropic
AI_API_KEY=sk-ant-api03-your-key-here
AI_MODEL_DEFAULT=claude-sonnet-4-6

# Auth
AUTH_JWT_SECRET=your-jwt-secret-minimum-32-chars
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_NAME=akis_sid

# GitHub OAuth (optional)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Email (mock | smtp | resend)
EMAIL_PROVIDER=mock

# URLs
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Development
DEV_MODE=true
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
