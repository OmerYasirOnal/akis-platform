# --- Runtime ---
NODE_ENV=development
AKIS_HOST=0.0.0.0
AKIS_PORT=3000
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000

# --- PostgreSQL / Drizzle ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=akis_v2
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/akis_v2

# --- MCP Endpoints (Single Door Policy) ---
GITHUB_MCP_BASE_URL=https://api.github.com/mcp
ATLASSIAN_MCP_BASE_URL=https://api.atlassian.com/mcp

# --- GitHub App (DI via Orchestrator) ---
GITHUB_APP_ID=
GITHUB_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# --- Atlassian (Jira/Confluence) ---
ATLASSIAN_ORG_ID=
ATLASSIAN_API_TOKEN=
ATLASSIAN_EMAIL=

# --- AI Service (Planner / Reflector) ---
AI_PROVIDER=openrouter
AI_API_KEY=
