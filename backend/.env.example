# AKIS Backend Environment Configuration
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# ==============================
# Database Configuration
# ==============================
DATABASE_URL=postgresql://user:password@localhost:5432/akis_v2

# ==============================
# Server Configuration
# ==============================
PORT=3000
NODE_ENV=development

# ==============================
# Frontend Configuration
# ==============================
FRONTEND_URL=http://localhost:5173

# ==============================
# CORS Configuration
# ==============================
CORS_ORIGINS=http://localhost:5173

# ==============================
# Authentication & Session
# ==============================
AUTH_COOKIE_NAME=akis_sid
AUTH_COOKIE_MAXAGE=604800
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_SECURE=false
# AUTH_COOKIE_DOMAIN=

# ==============================
# GitHub OAuth (for user login)
# ==============================
GITHUB_OAUTH_CLIENT_ID=your_github_oauth_client_id_here
GITHUB_OAUTH_CLIENT_SECRET=your_github_oauth_client_secret_here
GITHUB_OAUTH_CALLBACK_URL=http://localhost:3000/api/auth/github/callback

# ==============================
# GitHub MCP Gateway
# ==============================
# GitHub Personal Access Token
# Generate at: https://github.com/settings/tokens
# Required scopes: repo, read:org, read:packages
GITHUB_TOKEN=your_github_token_here

# MCP Gateway URL (local Docker gateway)
GITHUB_MCP_BASE_URL=http://localhost:4010/mcp

# ==============================
# Logging & Observability
# ==============================
LOG_LEVEL=info
# MCP_LOG_LEVEL=info
