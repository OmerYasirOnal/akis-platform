# =============================================================================
# AKIS Backend - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env files to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# NODE_ENV is set by scripts (pnpm dev defaults to "development", pnpm test sets "test")
# Do not set NODE_ENV in .env files - it will cause conflicts
# Defaults to "development" if unset
AKIS_HOST=0.0.0.0
AKIS_PORT=3000

# Base URLs (used for OAuth redirects and CORS)
# In production, set these to your actual domain URLs
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# CORS Origins (comma-separated list)
CORS_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/akis_v2
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=akis_v2
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# -----------------------------------------------------------------------------
# Authentication & Session
# -----------------------------------------------------------------------------
# JWT Secret (required in production, optional in dev/test)
# Generate with: openssl rand -base64 32
AUTH_JWT_SECRET=

# Cookie Configuration
AUTH_COOKIE_NAME=akis_sid
AUTH_COOKIE_MAXAGE=604800
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_SECURE=false
# AUTH_COOKIE_DOMAIN=localhost

# -----------------------------------------------------------------------------
# Email Configuration
# -----------------------------------------------------------------------------
EMAIL_PROVIDER=mock
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=15

# Resend Email Service (required when EMAIL_PROVIDER=resend)
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# -----------------------------------------------------------------------------
# OAuth Configuration (S0.4.2)
# -----------------------------------------------------------------------------
# OAuth credentials are used for user login via GitHub/Google
# These are SEPARATE from GitHub App credentials (see MCP section below)

# GitHub OAuth (for user login)
# Create OAuth App: https://github.com/settings/developers
# Callback URL: {BACKEND_URL}/auth/oauth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Google OAuth (for user login)
# Create OAuth Client: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {BACKEND_URL}/auth/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# GitHub App Configuration (MCP Integration)
# -----------------------------------------------------------------------------
# These credentials are for GitHub App installation (MCP adapter)
# NOT for OAuth user login - see OAuth section above
# GitHub App Setup: https://docs.github.com/en/apps/creating-github-apps

# GitHub App ID (from GitHub App settings)
GITHUB_APP_ID=

# GitHub Installation ID (after installing the app)
GITHUB_INSTALLATION_ID=

# GitHub App Private Key (PEM format)
# Download from GitHub App settings → Private keys
GITHUB_APP_PRIVATE_KEY_PEM=

# -----------------------------------------------------------------------------
# GitHub MCP Configuration (Required for Scribe agent)
# -----------------------------------------------------------------------------
# MCP (Model Context Protocol) enables agent communication with GitHub.
#
# Choose ONE of the following options:
#
# Option 1: Local Docker Gateway (recommended for development)
#   Start with: ./scripts/mcp-up.sh
#   Requires: GITHUB_TOKEN with scopes: repo, read:org
GITHUB_MCP_BASE_URL=http://localhost:4010/mcp
#
# Option 2: Remote GitHub Copilot MCP (requires GitHub Copilot subscription)
# GITHUB_MCP_BASE_URL=https://api.githubcopilot.com/mcp/
#
# GitHub Personal Access Token - create at: https://github.com/settings/tokens
# Required scopes: repo, read:org
# NOTE: This is SEPARATE from GITHUB_OAUTH_* (those are for user login)
GITHUB_TOKEN=
