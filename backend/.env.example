# =============================================================================
# AKIS Backend - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env files to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# NODE_ENV is set by scripts (pnpm dev defaults to "development", pnpm test sets "test")
# Do not set NODE_ENV in .env files - it will cause conflicts
# Defaults to "development" if unset
AKIS_HOST=0.0.0.0
AKIS_PORT=3000

# Base URLs (used for OAuth redirects and CORS)
# In production, set these to your actual domain URLs
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# CORS Origins (comma-separated list)
CORS_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/akis_v2
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=akis_v2
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# -----------------------------------------------------------------------------
# Authentication & Session
# -----------------------------------------------------------------------------
# JWT Secret (required in production, optional in dev/test)
# Generate with: openssl rand -base64 32
AUTH_JWT_SECRET=

# Cookie Configuration
AUTH_COOKIE_NAME=akis_sid
AUTH_COOKIE_MAXAGE=604800
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_SECURE=false
# AUTH_COOKIE_DOMAIN=localhost

# -----------------------------------------------------------------------------
# Email Configuration
# -----------------------------------------------------------------------------
EMAIL_PROVIDER=mock
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=15

# Resend Email Service (required when EMAIL_PROVIDER=resend)
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# -----------------------------------------------------------------------------
# OAuth Configuration (S0.4.2)
# -----------------------------------------------------------------------------
# OAuth credentials are used for user login via GitHub/Google
# These are SEPARATE from GitHub App credentials (see MCP section below)

# GitHub OAuth (for user login)
# Create OAuth App: https://github.com/settings/developers
# Callback URL: {BACKEND_URL}/auth/oauth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Google OAuth (for user login)
# Create OAuth Client: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {BACKEND_URL}/auth/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# GitHub App Configuration (MCP Integration)
# -----------------------------------------------------------------------------
# These credentials are for GitHub App installation (MCP adapter)
# NOT for OAuth user login - see OAuth section above
# GitHub App Setup: https://docs.github.com/en/apps/creating-github-apps

# GitHub App ID (from GitHub App settings)
GITHUB_APP_ID=

# GitHub Installation ID (after installing the app)
GITHUB_INSTALLATION_ID=

# GitHub App Private Key (PEM format)
# Download from GitHub App settings → Private keys
GITHUB_APP_PRIVATE_KEY_PEM=

# Alternative: Base64-encoded private key
# GITHUB_PRIVATE_KEY_BASE64=

# Personal Access Token (for MVP/Dev, optional if using GitHub App)
GITHUB_TOKEN=

# GitHub MCP Server Base URL (if using external MCP server)
# GitHub MCP Server Base URL
# Option 1 (Recommended): Local Docker gateway - run: ./scripts/mcp-up.sh
GITHUB_MCP_BASE_URL=http://localhost:4010/mcp

# Option 2: Remote hosted GitHub Copilot MCP (requires GitHub Copilot subscription)
# GITHUB_MCP_BASE_URL=https://api.githubcopilot.com/mcp/

# GitHub Personal Access Token for MCP operations (required for local gateway)
# Scopes: repo, read:org
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# Atlassian MCP Configuration
# -----------------------------------------------------------------------------
# Enable Atlassian MCP integration (set to 'true' to require credentials)
MCP_ATLASSIAN_ENABLED=false

# Atlassian credentials (required when MCP_ATLASSIAN_ENABLED=true or NODE_ENV=production)
ATLASSIAN_ORG_ID=
ATLASSIAN_API_TOKEN=
ATLASSIAN_EMAIL=
ATLASSIAN_MCP_BASE_URL=

# -----------------------------------------------------------------------------
# AI Provider Configuration
# -----------------------------------------------------------------------------
AI_PROVIDER=mock

# API Keys (provider-specific)
AI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Base URLs (provider-specific)
AI_BASE_URL=
OPENROUTER_BASE_URL=
OPENAI_BASE_URL=

# Model Names (provider-specific)
AI_MODEL_DEFAULT=
AI_MODEL_PLANNER=
AI_MODEL_VALIDATION=
OPENROUTER_MODEL=
OPENAI_MODEL=

# =============================================================================
# Environment Variable Mapping Checklist
# =============================================================================
#
# OAuth vs GitHub App Credentials:
# ────────────────────────────────────────────────────────────────────────────
# 
# ✅ OAuth Login Credentials (for user authentication):
#    - GITHUB_OAUTH_CLIENT_ID / GITHUB_OAUTH_CLIENT_SECRET
#    - GOOGLE_OAUTH_CLIENT_ID / GOOGLE_OAUTH_CLIENT_SECRET
#    - Used for: User login via "Continue with GitHub/Google"
#    - Callback URLs: {BACKEND_URL}/auth/oauth/{provider}/callback
#
# ✅ GitHub App Credentials (for MCP integration):
#    - GITHUB_APP_ID / GITHUB_INSTALLATION_ID / GITHUB_APP_PRIVATE_KEY_PEM
#    - Used for: GitHub API access via MCP adapter (agents)
#    - Purpose: Access repositories, create PRs, etc.
#
# ⚠️  These are SEPARATE credential sets with different purposes!
#
# =============================================================================
# Production vs Development Behavior
# =============================================================================
#
# Required in Production:
#   - AUTH_JWT_SECRET (min 32 chars)
#   - AUTH_COOKIE_SECURE=true (HTTPS only)
#   - DATABASE_URL
#   - OAuth credentials (if OAuth is enabled)
#
# Optional in Development:
#   - OAuth credentials (can be omitted for email/password only)
#   - GitHub App credentials (can be omitted if not using MCP)
#   - Atlassian credentials (unless MCP_ATLASSIAN_ENABLED=true)
#
# =============================================================================
