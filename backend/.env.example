# Backend Environment Variables
# Copy this file to .env and fill in your values

# Application
NODE_ENV=development
AKIS_HOST=0.0.0.0
AKIS_PORT=3000
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/akis_v2
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=akis_v2
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Authentication
AUTH_COOKIE_NAME=akis_sid
AUTH_COOKIE_MAXAGE=604800
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_DOMAIN=

# AI Provider (openrouter, openai, or mock)
AI_PROVIDER=mock
AI_API_KEY=

# GitHub MCP (optional)
GITHUB_MCP_BASE_URL=
GITHUB_APP_ID=
GITHUB_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_PEM=

# Atlassian MCP (optional - only required if MCP_ATLASSIAN_ENABLED=true)
MCP_ATLASSIAN_ENABLED=false
ATLASSIAN_MCP_BASE_URL=
ATLASSIAN_ORG_ID=
ATLASSIAN_API_TOKEN=
ATLASSIAN_EMAIL=

# Logging
LOG_LEVEL=info
