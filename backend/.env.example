# =============================================================================
# AKIS Backend - Environment Variables Template
# =============================================================================
# Copy to .env.local and fill in your secrets (NEVER commit .env.local)
# =============================================================================

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
AKIS_HOST=0.0.0.0
AKIS_PORT=3000
PORT=3000

# Base URLs
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Local Dev Config
LOG_LEVEL=info
TRUST_PROXY=false
CSRF_ENABLED=false

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/akis_v2

# -----------------------------------------------------------------------------
# Authentication & Session
# -----------------------------------------------------------------------------
AUTH_JWT_SECRET='test-jwt-secret-at-least-32-chars-long'
AUTH_COOKIE_NAME=akis_sid
AUTH_COOKIE_MAXAGE=604800

# -----------------------------------------------------------------------------
# Email Configuration (Mock by default)
# -----------------------------------------------------------------------------
EMAIL_PROVIDER=mock
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=15

# Resend Configuration (used when EMAIL_PROVIDER=resend)
# RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=test@example.com

# SMTP Configuration (used when EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_SECURE=false
# SMTP_FROM_NAME=AKIS Platform
# SMTP_FROM_EMAIL=noreply@akisflow.com
# SMTP_REPLY_TO=support@akisflow.com

# Logo URL for email templates (optional — falls back to text header)
# PUBLIC_LOGO_URL=https://staging.akisflow.com/brand/logo.png

# -----------------------------------------------------------------------------
# AI Service Configuration (Mock by default - see .env.local for real keys)
# -----------------------------------------------------------------------------
AI_PROVIDER=mock
# Required for encrypted OAuth token writes (GitHub/Google/Integrations callback)
# If missing, new OAuth token writes are strict-blocked for security.
AI_KEY_ENCRYPTION_KEY=base64:REPLACE_WITH_32_BYTE_BASE64
AI_KEY_ENCRYPTION_KEY_VERSION=v1
AI_DETERMINISTIC_MODE=true
AI_FORCE_DETERMINISTIC_PLAN=true
AI_SCRIBE_MODEL_ALLOWLIST=gpt-4o-mini,gpt-4o,gpt-4.1-mini

# To enable real AI: Create backend/.env.local with:
# AI_PROVIDER=openrouter
# AI_API_KEY=sk-or-v1-***
# AI_MODEL_DEFAULT=meta-llama/llama-3.3-70b-instruct:free
# AI_MODEL_PLANNER=tngtech/deepseek-r1t-chimera:free
# AI_MODEL_VALIDATION=google/gemini-2.0-flash-exp:free
# OPENROUTER_SITE_URL=https://your-site.com
# OPENROUTER_APP_NAME=Your App Name
#
# Scribe per-user keys use OpenAI-compatible endpoints (defaults to https://api.openai.com/v1).
# You can override with:
# OPENAI_BASE_URL=https://api.openai.com/v1

# -----------------------------------------------------------------------------
# OAuth Configuration (Placeholders - use .env.local for real secrets)
# -----------------------------------------------------------------------------
# GITHUB_OAUTH_CLIENT_ID=***
# GITHUB_OAUTH_CLIENT_SECRET=***
# GOOGLE_OAUTH_CLIENT_ID=***
# GOOGLE_OAUTH_CLIENT_SECRET=***

# -----------------------------------------------------------------------------
# GitHub App Configuration (Placeholders - use .env.local for real secrets)
# -----------------------------------------------------------------------------
# GITHUB_APP_ID=***
# GITHUB_INSTALLATION_ID=***
# GITHUB_APP_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# -----------------------------------------------------------------------------
# GitHub MCP Configuration
# -----------------------------------------------------------------------------
# GITHUB_MCP_BASE_URL=http://localhost:4010/mcp
# GITHUB_TOKEN=***

# -----------------------------------------------------------------------------
# Atlassian MCP (Disabled by default)
# -----------------------------------------------------------------------------
MCP_ATLASSIAN_ENABLED=false

# -----------------------------------------------------------------------------
# Test Configuration
# -----------------------------------------------------------------------------
SCRIBE_DEV_GITHUB_BOOTSTRAP=false
SKIP_MCP_TESTS=true

# -----------------------------------------------------------------------------
# Integrations - GitHub OAuth (for Dashboard Integrations page)
# -----------------------------------------------------------------------------
# Create a GitHub OAuth App at: https://github.com/settings/developers
# Set Authorization callback URL to: http://localhost:3000/api/integrations/github/oauth/callback
# GITHUB_OAUTH_CLIENT_ID=your_client_id
# GITHUB_OAUTH_CLIENT_SECRET=your_client_secret
GITHUB_OAUTH_CALLBACK_URL=http://localhost:3000/api/integrations/github/oauth/callback
APP_PUBLIC_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Smart Automations - Slack Integration
# -----------------------------------------------------------------------------
# Slack Bot Token for sending notifications (xoxb-xxx format)
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# Default Slack channel for notifications (C0123456789 or #channel-name)
# SLACK_DEFAULT_CHANNEL=C0123456789

# -----------------------------------------------------------------------------
# AI Retry Configuration
# -----------------------------------------------------------------------------
# AI_PLANNER_MAX_RETRIES=3
# AI_RETRY_BASE_DELAY_MS=1000

# -----------------------------------------------------------------------------
# GitHub Webhooks
# -----------------------------------------------------------------------------
# GITHUB_WEBHOOK_SECRET=your_webhook_secret

# -----------------------------------------------------------------------------
# Atlassian OAuth
# -----------------------------------------------------------------------------
# ATLASSIAN_OAUTH_CALLBACK_URL=http://localhost:3000/api/integrations/atlassian/oauth/callback

# -----------------------------------------------------------------------------
# Piri RAG Engine (M2)
# -----------------------------------------------------------------------------
# Base URL for Piri RAG service (Docker: http://piri:8000, Local: http://localhost:8000)
# PIRI_BASE_URL=http://localhost:8000
# OpenAI key for Piri (falls back to OPENAI_API_KEY if not set)
# PIRI_OPENAI_API_KEY=
# PIRI_OPENAI_MODEL=gpt-4o-mini
# PIRI_RERANKING=true
# PIRI_EMBEDDING_MODEL=intfloat/multilingual-e5-small

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable/disable unstable or experimental routes (default: false in production)
FEATURE_FLAG_UNSTABLE_ROUTES=false
# Contract/gate rollout controls (M2 reliability)
AGENT_CONTRACT_ENFORCEMENT_MODE=observe
AGENT_CONTRACT_RETRY_POLICY=abort
RELIABILITY_CANARY_ENABLED=false
RELIABILITY_CANARY_SALT=akis-reliability-v1
AGENT_CONTRACT_CANARY_PERCENT=100
VERIFICATION_GATE_ROLLOUT_MODE=observe
VERIFICATION_GATE_CANARY_PERCENT=100
FRESHNESS_SCHEDULER_ENABLED=false
FRESHNESS_SCHEDULER_INTERVAL_MINUTES=360
FRESHNESS_THRESHOLD_DAYS=90
FRESHNESS_AGING_THRESHOLD_DAYS=45
MCP_GATEWAY_TIMEOUT_MS=8000
MCP_GATEWAY_RETRY_COUNT=2
# Marketplace proposal generator mode
# false: template-only (default, safe)
# true: allow optional LLM hook path
MARKETPLACE_PROPOSAL_LLM_ENABLED=false

# -----------------------------------------------------------------------------
# Pipeline Dev Mode
# -----------------------------------------------------------------------------
DEV_MODE=false
DEV_SKIP_AUTH=false
