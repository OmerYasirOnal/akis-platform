{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StructuredSpec",
  "description": "Structured software specification produced by the Scribe agent",
  "type": "object",
  "required": ["title", "problemStatement", "userStories", "acceptanceCriteria", "technicalConstraints", "outOfScope"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 3,
      "description": "Concise project name (3-8 words)"
    },
    "problemStatement": {
      "type": "string",
      "minLength": 10,
      "description": "What problem does this solve? (2-4 sentences)"
    },
    "userStories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["persona", "action", "benefit"],
        "properties": {
          "persona": { "type": "string", "minLength": 1 },
          "action": { "type": "string", "minLength": 1 },
          "benefit": { "type": "string", "minLength": 1 }
        }
      }
    },
    "acceptanceCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "given", "when", "then"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "given": { "type": "string", "minLength": 1 },
          "when": { "type": "string", "minLength": 1 },
          "then": { "type": "string", "minLength": 1 }
        }
      }
    },
    "technicalConstraints": {
      "type": "object",
      "properties": {
        "stack": { "type": "string" },
        "integrations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "nonFunctional": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "outOfScope": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
