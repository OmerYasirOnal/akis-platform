# --- Runtime ---
NODE_ENV=development
AKIS_HOST=0.0.0.0
AKIS_PORT=3000
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000

# --- PostgreSQL / Drizzle ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=akis
POSTGRES_USER=akis_user
POSTGRES_PASSWORD=change_me
# Drizzle-compatible URL (preferred)
DATABASE_URL=postgres://akis_user:change_me@localhost:5432/akis

# --- MCP Endpoints (Single Door Policy) ---
# All external systems must be accessed via MCP Client Adapters.
GITHUB_MCP_BASE_URL=https://api.github.com/mcp
ATLASSIAN_MCP_BASE_URL=https://api.atlassian.com/mcp

# --- GitHub App (tokens fetched by Orchestrator, injected to adapters) ---
GITHUB_APP_ID=
GITHUB_INSTALLATION_ID=
# Wrap PEM in quotes if multi-line
GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# --- Atlassian (Jira/Confluence) ---
ATLASSIAN_ORG_ID=
ATLASSIAN_API_TOKEN=
ATLASSIAN_EMAIL=

# --- AI Service (Planner / Reflector) ---
# Provider-neutral; actual calls are encapsulated in services/mcp/ai/AIService.ts
AI_PROVIDER=openai
AI_API_KEY=

# --- Security / Misc ---
# add extra secrets here; never commit a real .env