# AKIS Platform - Root Environment Variables
# Copy this file to .env and configure with your actual values

# This file is for workspace-level configuration (if needed)
# Individual packages (backend, frontend) have their own .env.example files

# ----------------------------------------------------------------------------
# CI / Workspace defaults (safe placeholders)
# ----------------------------------------------------------------------------

# Flag used by scripts to detect CI environments
CI=false

# Shared pnpm cache directory override (optional)
# PNPM_HOME="${HOME}/.pnpm"

# Backend service URL exposed to the frontend during local development
# BACKEND_URL=http://localhost:3000

# Example test database URL (used by CI jobs)
# TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/akis_v2_test
