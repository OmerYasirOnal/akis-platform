# syntax=docker/dockerfile:1
# AKIS Backend Dockerfile — Staging/Production
# Pipeline code lives at backend/src/pipeline/ (consolidated)
# Build context: REPO ROOT (not backend/)
#
# Usage:
#   docker build -f Dockerfile.backend -t akis-backend .
#
# Optimization notes (ARM64 OCI Free Tier — 1 OCPU, 6GB RAM):
#   - python3/make/g++ REMOVED: all deps are pure JS (bcryptjs, not bcrypt)
#   - pnpm installed ONCE in builder, reused in prod via COPY (saves ~50s)
#   - BUILD_COMMIT arg moved AFTER dependency layers to avoid cache busting
#   - pnpm store cache mount speeds up repeat installs on the same host

# =============================================================================
# Stage 1: Build
# =============================================================================
FROM node:20-alpine AS builder

# python3/make/g++ NOT needed — all npm deps are pure JavaScript:
#   bcryptjs (not bcrypt), pg, drizzle-orm, fastify, jose, zod, etc.
# wget NOT needed in builder (only used in production HEALTHCHECK).
RUN npm install -g pnpm@9

# Recreate repo structure for TypeScript compilation
# tsconfig rootDir=".." preserves dist/backend/src/ output path
WORKDIR /build/backend

# Copy package files first (for layer caching)
COPY backend/package.json backend/pnpm-lock.yaml ./

# Install all dependencies (including devDependencies for build).
# --mount=type=cache persists the pnpm store across builds on the same host,
# so repeat installs only download changed packages (~2-3 min → ~30s).
RUN --mount=type=cache,id=pnpm-store,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile

# Copy TypeScript config
COPY backend/tsconfig.json ./
COPY backend/drizzle.config.ts ./

# Copy backend source (includes pipeline code at src/pipeline/)
COPY backend/src ./src

# Copy root package.json for "type": "module" — rootDir=".." needs this
# at /build/package.json so Node.js ESM resolution works correctly.
COPY package.json /build/package.json

# Build TypeScript — output goes to dist/backend/src/
RUN pnpm run build

# Remove devDependencies
RUN pnpm prune --prod

# =============================================================================
# Stage 2: Production
# =============================================================================
FROM node:20-alpine AS production

# Install runtime dependencies: wget (healthcheck), dumb-init (PID 1), pnpm (migrations).
# python3/make/g++ NOT needed at runtime.
RUN apk add --no-cache wget dumb-init && npm install -g pnpm@9

# Create non-root user
RUN addgroup -g 1001 -S akis && \
    adduser -S -D -u 1001 -h /home/akis -s /sbin/nologin -G akis akis && \
    mkdir -p /home/akis/.local/share && \
    chown -R akis:akis /home/akis

WORKDIR /app

# Copy built files from builder
# dist/ contains: backend/src/ (compiled backend + pipeline)
COPY --from=builder --chown=akis:akis /build/backend/dist ./dist
COPY --from=builder --chown=akis:akis /build/backend/node_modules ./node_modules
COPY --from=builder --chown=akis:akis /build/backend/package.json ./

# Copy migrations (for runtime migration support)
COPY --chown=akis:akis backend/migrations ./migrations
COPY --chown=akis:akis backend/drizzle.config.ts ./

# BUILD_COMMIT is set AFTER all COPY/RUN layers so changing the commit SHA
# does NOT bust the Docker cache for dependency installation or compilation.
# Only the ENV layer and everything below it is invalidated per deploy.
ARG BUILD_COMMIT=unknown
ARG BUILD_TIME=unknown
ARG APP_VERSION=0.2.0

ENV BUILD_COMMIT=${BUILD_COMMIT}
ENV BUILD_TIME=${BUILD_TIME}
ENV APP_VERSION=${APP_VERSION}

USER akis

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:3000/health || exit 1

ENTRYPOINT ["dumb-init", "--"]

# Entry point: dist/server.js (tsconfig rootDir="./src" flattens output)
CMD ["node", "dist/server.js"]
