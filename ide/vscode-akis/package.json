{
  "name": "akis-ide",
  "displayName": "AKIS IDE",
  "description": "AI-powered development environment — run agents, monitor jobs, index code, and chat with Scribe, Trace, Proto & Piri directly from VS Code.",
  "version": "0.1.0",
  "publisher": "akis-platform",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Machine Learning",
    "Programming Languages"
  ],
  "keywords": [
    "ai",
    "agent",
    "rag",
    "testing",
    "documentation",
    "akis"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "akis-explorer",
          "title": "AKIS",
          "icon": "media/akis-icon.svg"
        }
      ]
    },
    "views": {
      "akis-explorer": [
        {
          "id": "akis-agents",
          "name": "Agents"
        },
        {
          "id": "akis-jobs",
          "name": "Jobs"
        },
        {
          "id": "akis-files",
          "name": "Indexed Files"
        }
      ]
    },
    "commands": [
      {
        "command": "akis.openChat",
        "title": "AKIS: Open Agent Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "akis.runAgent",
        "title": "AKIS: Run Agent",
        "icon": "$(play)"
      },
      {
        "command": "akis.indexWorkspace",
        "title": "AKIS: Index Workspace"
      },
      {
        "command": "akis.searchCode",
        "title": "AKIS: Search Code"
      },
      {
        "command": "akis.sendTerminalOutput",
        "title": "AKIS: Send Terminal Output to Agent"
      },
      {
        "command": "akis.viewJobDetail",
        "title": "AKIS: View Job Details"
      },
      {
        "command": "akis.configure",
        "title": "AKIS: Configure Connection"
      },
      {
        "command": "akis.refreshIndex",
        "title": "AKIS: Refresh Index",
        "icon": "$(refresh)"
      },
      {
        "command": "akis.sendFileToAgent",
        "title": "AKIS: Send File to Agent",
        "icon": "$(arrow-up)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "akis.openChat",
          "when": "view == akis-agents",
          "group": "navigation"
        },
        {
          "command": "akis.runAgent",
          "when": "view == akis-agents",
          "group": "navigation"
        },
        {
          "command": "akis.refreshIndex",
          "when": "view == akis-files",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "akis.sendFileToAgent",
          "group": "akis@1"
        }
      ]
    },
    "configuration": {
      "title": "AKIS IDE",
      "properties": {
        "akis.serverUrl": {
          "type": "string",
          "default": "https://staging.akisflow.com",
          "description": "AKIS Platform server URL"
        },
        "akis.apiToken": {
          "type": "string",
          "default": "",
          "description": "API authentication token"
        },
        "akis.autoIndex": {
          "type": "boolean",
          "default": false,
          "description": "Automatically index workspace on open"
        },
        "akis.defaultAgent": {
          "type": "string",
          "enum": [
            "scribe",
            "trace",
            "proto",
            "piri"
          ],
          "default": "scribe",
          "description": "Default agent for quick actions"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "eventsource": "^2.0.2"
  }
}
