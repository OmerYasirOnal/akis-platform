# OS
Thumbs.db

# Temporary files
tmp/
temp/
.cache/
cookies.txt
*.cookie

# Nested Lockfiles (Monorepo Rule)
# NOTE: backend/pnpm-lock.yaml is NOT ignored — required for Docker builds
frontend/pnpm-lock.yaml
backend/package-lock.json
mcp-gateway/pnpm-lock.yaml

# Build Artifacts (Recursive)
**/dist

# Playwright artifacts
frontend/playwright-report/
frontend/test-results/

# Project Tracking Spreadsheets (may contain internal notes)
docs/AKIS_Proje_Takibi*.xlsx
*.xlsx

# Binary research documents (keep as markdown summaries instead)
# EXCEPT graduation/academic docs which are archived intentionally
docs/*.pdf
docs/*.docx
docs/~$*.docx
# Allow academic archive (graduation documents)
!docs/academic/**/*.pdf
!docs/academic/**/*.docx

# Dev process artifacts
*.pid
.pnpm-store/
backend/_tmp_*

# One-off binary reports (not tracked)
AKIS_UI_Audit_Report.docx
.cursor/plans/

# Scratch/external AI session artifacts (never commit)
CURSOR_PROMPT*.md
STAGING_DEPLOY_CHECKLIST.md
staging_env_template.env
staging_smoke_test.sh

