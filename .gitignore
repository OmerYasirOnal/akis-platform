# Dependencies
node_modules/
.pnp
.pnp.js

# Testing
coverage/
*.lcov
.nyc_output

# Production
dist/
build/
*.log

# Environment variables - NEVER commit secrets!
# Root-level env files
.env
.env.local
.env.*.local
.env.mcp.local

# Backend env files
backend/.env
backend/.env.local
backend/.env.*.local
!backend/.env.example

# Frontend env files
frontend/.env
frontend/.env.local
frontend/.env.*.local
!frontend/.env.example

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Cursor MCP config (may contain secrets)
.cursor/mcp.json
!.cursor/mcp.json.example

# TypeScript
*.tsbuildinfo

# Database
*.db
*.sqlite
*.sqlite3

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS
Thumbs.db

# Temporary files
tmp/
temp/
.cache/

# Nested Lockfiles (Monorepo Rule)
frontend/pnpm-lock.yaml
backend/pnpm-lock.yaml
backend/package-lock.json
mcp-gateway/pnpm-lock.yaml

# Build Artifacts (Recursive)
**/dist

# Playwright artifacts
frontend/playwright-report/
frontend/test-results/

# Project Tracking Spreadsheets (may contain internal notes)
docs/AKIS_Proje_Takibi*.xlsx
*.xlsx

# Binary research documents (keep as markdown summaries instead)
# EXCEPT graduation/academic docs which are archived intentionally
docs/*.pdf
docs/*.docx
docs/~$*.docx
# Allow academic archive (graduation documents)
!docs/academic/**/*.pdf
!docs/academic/**/*.docx
