node_modules/
.pnp
.pnp.js

# Testing
coverage/
*.lcov
.nyc_output

# Production
dist/
build/
*.log

# Environment variables - NEVER commit secrets!
# Root-level env files
.env
.env.local
.env.*.local
.env.mcp.local
.secrets/
*.env.snapshot
*.env.staging*

# Backend env files
backend/.env
backend/.env.local
backend/.env.staging
backend/.env.*.local
!backend/.env.example

# Frontend env files
frontend/.env
frontend/.env.local
frontend/.env.*.local
!frontend/.env.example

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

