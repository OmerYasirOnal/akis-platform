# Example env for AKIS frontend (do NOT put secrets here)

VITE_API_URL=http://localhost:3000
VITE_BACKEND_URL=http://localhost:3000

VITE_DEFAULT_LOCALE=en
VITE_BRAND_NAME=AKIS

VITE_MOTION_ENABLED=true
VITE_CURSOR_GLOW_ENABLED=true
VITE_AGENTS_ENABLED=true
VITE_ENABLE_DEV_LOGIN=false

# Waitlist form URL (Google Forms or similar)
VITE_WAITLIST_URL=https://forms.gle/3aVfEh1Q8929DSY2A

# Contact page phone (optional)
# VITE_CONTACT_PHONE=+90-xxx-xxx-xx-xx

# NOTE: In staging/production, do NOT set VITE_BACKEND_URL.
# The frontend resolves the API base URL from window.location.origin via getApiBaseUrl().
