# AKIS Frontend Environment Variables
# Copy this file to .env and configure with your actual values

# ============================================================================
# API CONFIGURATION
# ============================================================================

# Backend API URL (required for API calls)
# In development: http://localhost:3000
# In production: https://api.akis.example.com
VITE_BACKEND_URL=http://localhost:3000

# Alternative API URL key (deprecated, use VITE_BACKEND_URL)
# VITE_API_URL=http://localhost:3000

# ============================================================================
# FEATURE FLAGS (Optional)
# ============================================================================

# Enable agent execution features (scribe, trace, proto)
# Set to 'true' to enable agent execution UI
VITE_AGENTS_ENABLED=true

# ============================================================================
# CI/CD & TESTING NOTES
# ============================================================================
# For CI environments:
# - VITE_BACKEND_URL can be set to a test backend URL or left as default
# - VITE_AGENTS_ENABLED can be 'false' for basic UI tests
# - No sensitive credentials are required for frontend builds
