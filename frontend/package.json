{
  "name": "akis-frontend",
  "private": true,
  "version": "0.2.0",
  "description": "AKIS Platform Frontend — React 19 SPA with chat-centric AI agent interface",
  "author": "Ömer Yasir Önal <omeryasironal@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/OmerYasirOnal/akis-platform-devolopment",
    "directory": "devagents/frontend"
  },
  "type": "module",
  "engines": {
    "node": ">=22.12.0 || >=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:e2e": "playwright test",
    "generate:types": "openapi-typescript http://localhost:3000/openapi.json -o src/services/api/openapi-types.ts"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@stackblitz/sdk": "^1.11.0",
    "@tailwindcss/typography": "^0.5.19",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.9.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.1.16",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "dockview": "^5.1.0",
    "globals": "^16.5.0",
    "openapi-typescript": "^7.10.1",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.16",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.1.7",
    "vitest": "^4.0.7"
  }
}
