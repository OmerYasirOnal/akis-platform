// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Enums - Type Safety
// ============================================

enum AccountType {
  User
  Organization
}

enum RepositorySelection {
  all
  selected
}

enum JobStatus {
  pending
  running
  completed
  failed
}

enum JobType {
  scribe_run
  repo_analysis
}

enum LogLevel {
  debug
  info
  warn
  error
}

// ============================================
// Module A: GitHub App/OAuth - User & Identity Management
// ============================================

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique @db.VarChar(255)
  name      String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  identities    UserIdentity[]
  installations Installation[]
  sessions      Session[]
  jobs          Job[]

  @@index([email])
  @@map("users")
}

model UserIdentity {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  provider          String   @db.VarChar(50) // 'github', 'gitlab', etc.
  providerUserId    String   @map("provider_user_id") @db.VarChar(255)
  providerLogin     String?  @map("provider_login") @db.VarChar(255)
  providerEmail     String?  @map("provider_email") @db.VarChar(255)
  providerAvatarUrl String?  @map("provider_avatar_url") @db.Text
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@index([provider, providerUserId])
  @@map("user_identities")
}

model Installation {
  id                  String              @id @default(uuid()) @db.Uuid
  installationId      BigInt              @unique @map("installation_id")
  userId              String?             @map("user_id") @db.Uuid
  accountType         AccountType         @map("account_type")
  accountLogin        String              @map("account_login") @db.VarChar(255)
  accountId           BigInt?             @map("account_id")
  repositorySelection RepositorySelection @map("repository_selection")
  permissions         Json? // {contents: 'write', pull_requests: 'write', ...}
  appSlug             String?             @map("app_slug") @db.VarChar(255)
  htmlUrl             String?             @map("html_url") @db.Text
  status              String              @default("active") @db.VarChar(20) // 'active' | 'suspended' | 'uninstalled'
  installedAt         DateTime            @map("installed_at")
  updatedAt           DateTime            @default(now()) @updatedAt @map("updated_at")
  uninstalledAt       DateTime?           @map("uninstalled_at")

  user         User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)
  repositories InstallationRepository[]
  jobs         Job[]

  @@index([installationId])
  @@index([userId])
  @@index([status])
  @@map("installations")
}

model InstallationRepository {
  id                 String    @id @default(uuid()) @db.Uuid
  installationUuid   String    @map("installation_uuid") @db.Uuid
  repositoryId       BigInt    @map("repository_id")
  repositoryFullName String    @map("repository_full_name") @db.VarChar(255)
  private            Boolean   @default(false)
  defaultBranch      String    @default("main") @map("default_branch") @db.VarChar(255)
  addedAt            DateTime  @default(now()) @map("added_at")
  removedAt          DateTime? @map("removed_at")

  installation Installation @relation(fields: [installationUuid], references: [id], onDelete: Cascade)

  @@unique([installationUuid, repositoryId])
  @@index([installationUuid])
  @@index([repositoryFullName])
  @@map("installation_repositories")
}

model Session {
  id             String    @id @db.VarChar(255) // Session ID (UUID or secure random)
  userId         String    @map("user_id") @db.Uuid
  provider       String    @db.VarChar(50) // 'github'
  accessToken    String    @map("access_token") @db.Text // MUST be encrypted (Phase-2, AES-GCM app-level)
  refreshToken   String?   @map("refresh_token") @db.Text // MUST be encrypted (Phase-2, AES-GCM app-level)
  tokenExpiresAt DateTime? @map("token_expires_at")
  scopes         String[] // OAuth scopes granted
  createdAt      DateTime  @default(now()) @map("created_at")
  expiresAt      DateTime  @map("expires_at") // Session expiry (e.g., 30 days)
  lastAccessedAt DateTime  @default(now()) @map("last_accessed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// ============================================
// Module B: MCP Tooling Layer - Job Management
// ============================================

model Job {
  id               String  @id @default(uuid()) @db.Uuid
  userId           String? @map("user_id") @db.Uuid
  installationUuid String? @map("installation_uuid") @db.Uuid
  actorMode        String  @map("actor_mode") @db.VarChar(20) // 'oauth_user' | 'app_bot' | 'service_account'
  actorGithubLogin String? @map("actor_github_login") @db.VarChar(255)

  repositoryFullName String  @map("repository_full_name") @db.VarChar(255)
  branch             String  @db.VarChar(255)
  baseBranch         String? @map("base_branch") @db.VarChar(255)

  jobType JobType   @map("job_type")
  status  JobStatus @default(pending)

  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  result Json? // {pr_number, pr_url, files_changed, das_score, ...}
  error  Json? // {code, message, stack}

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  installation Installation? @relation(fields: [installationUuid], references: [id], onDelete: SetNull)
  logs         JobLog[]

  @@index([userId])
  @@index([installationUuid])
  @@index([installationUuid, createdAt(sort: Desc)])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("jobs")
}

model JobLog {
  id        String   @id @default(uuid()) @db.Uuid
  jobId     String   @map("job_id") @db.Uuid
  timestamp DateTime @default(now())
  level     LogLevel
  operation String?  @db.VarChar(100) // 'github.list_repos', 'github.create_pr', etc.
  message   String   @db.Text
  metadata  Json? // {duration_ms, pr_number, file_count, ...}

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, timestamp(sort: Desc)])
  @@map("job_logs")
}
