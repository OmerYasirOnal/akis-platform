{$DOMAIN:app.akisflow.com} {
	# API proxy
	handle /api/* {
		reverse_proxy backend:3000
	}
	# Auth API routes → Backend (SPA auth pages fall through to frontend)
	handle /auth/oauth/* {
		reverse_proxy backend:3000
	}
	handle /auth/signup/* {
		reverse_proxy backend:3000
	}
	handle /auth/login/* {
		reverse_proxy backend:3000
	}
	@auth_api path /auth/signup /auth/login /auth/logout /auth/me /auth/health /auth/verify-email /auth/resend-code /auth/update-preferences
	handle @auth_api {
		reverse_proxy backend:3000
	}
	handle /health {
		reverse_proxy backend:3000
	}
	handle /ready {
		reverse_proxy backend:3000
	}

	# OpenAPI / Swagger UI → Backend
	handle /api/docs* {
		reverse_proxy backend:3000
	}
	handle /openapi.json {
		reverse_proxy backend:3000
	}

	# Frontend SPA
	handle {
		root * /srv/frontend
		try_files {path} /index.html
		file_server
		encode gzip
	}

	# Security headers
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}

	log {
		output file /var/log/caddy/access.log
		format json
	}
}
