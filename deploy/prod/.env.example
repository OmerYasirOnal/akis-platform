# AKIS Production Environment Variables
# Copy this to .env and fill in real values

# Domain
DOMAIN=app.akisflow.com

# Database
POSTGRES_USER=akis
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=akis_prod

# Authentication
AUTH_JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_LONG_RANDOM
AUTH_COOKIE_NAME=akis_session
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_MAXAGE=604800
AUTH_COOKIE_DOMAIN=.akisflow.com

# URLs
BACKEND_URL=https://app.akisflow.com
FRONTEND_URL=https://app.akisflow.com
CORS_ORIGINS=https://app.akisflow.com

# Email
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=noreply@akisflow.com

# AI Provider
AI_PROVIDER=openai
AI_API_KEY=sk-xxxx
AI_KEY_ENCRYPTION_KEY=CHANGE_ME_32_BYTES_HEX
AI_KEY_ENCRYPTION_KEY_VERSION=v1

# OAuth
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_URL=https://app.akisflow.com/auth/github/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# MCP Gateway
GITHUB_MCP_BASE_URL=http://mcp-gateway:4010
GITHUB_TOKEN=ghp_xxxx

# Stripe Billing
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
STRIPE_PRICE_PRO=price_xxxx
STRIPE_PRICE_PRO_PLUS=price_xxxx
STRIPE_PRICE_TEAM=price_xxxx

# Container versions
BACKEND_VERSION=latest
MCP_VERSION=latest
