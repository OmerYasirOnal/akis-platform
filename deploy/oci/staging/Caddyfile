# AKIS Platform - Staging Caddyfile
# =========================================================================
#
# Reverse proxy configuration for staging environment
# Domain: staging.akisflow.com
#
# Handles:
# - HTTPS termination (automatic Let's Encrypt)
# - Static frontend serving (Vite-built SPA)
# - API routing to Fastify backend
# - Security headers
#
# =========================================================================

{
    email {$ACME_EMAIL:admin@akisflow.com}
}

staging.akisflow.com {
    # Enable compression
    encode gzip zstd

    # Security headers
    header {
        # Prevent MIME type sniffing
        X-Content-Type-Options "nosniff"
        # Clickjacking protection
        X-Frame-Options "DENY"
        # XSS protection (legacy browsers)
        X-XSS-Protection "1; mode=block"
        # Referrer policy
        Referrer-Policy "strict-origin-when-cross-origin"
        # Remove server header
        -Server
    }

    # =======================================================================
    # Health/Ready/Version endpoints (no auth, for monitoring)
    # =======================================================================
    handle /health {
        reverse_proxy backend:3000
    }

    handle /ready {
        reverse_proxy backend:3000
    }

    handle /version {
        reverse_proxy backend:3000
    }

    # =======================================================================
    # API routes → Backend
    # =======================================================================
    handle /api/* {
        reverse_proxy backend:3000
    }

    # =======================================================================
    # Auth API routes → Backend
    # Only proxy backend API paths; SPA auth pages (/auth/privacy-consent,
    # /auth/welcome-beta) fall through to the static file handler below.
    # =======================================================================
    handle /auth/oauth/* {
        reverse_proxy backend:3000
    }
    handle /auth/signup/* {
        reverse_proxy backend:3000
    }
    handle /auth/login/* {
        reverse_proxy backend:3000
    }
    @auth_api path /auth/signup /auth/login /auth/logout /auth/me /auth/health /auth/verify-email /auth/resend-code /auth/update-preferences
    handle @auth_api {
        reverse_proxy backend:3000
    }

    # =======================================================================
    # OpenAPI / Swagger UI → Backend (at /api/docs)
    # =======================================================================
    handle /api/docs* {
        reverse_proxy backend:3000
    }

    handle /openapi.json {
        reverse_proxy backend:3000
    }

    # =======================================================================
    # Metrics endpoint → Backend (consider restricting in production)
    # =======================================================================
    handle /metrics {
        reverse_proxy backend:3000
    }

    # =======================================================================
    # Static frontend files (SPA with fallback to index.html)
    # =======================================================================
    handle {
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }

    # =======================================================================
    # Access logging
    # =======================================================================
    log {
        output stdout
        format console
        level INFO
    }
}

# =========================================================================
# classcheck.site - Co-hosted QR Service (DO NOT REMOVE)
# =========================================================================
# This site runs in a separate Docker container on the same VM.
# Caddy reverse_proxies to it via host.docker.internal.
# The port is configured via CLASSCHECK_PORT env var (default: 3001).
# NOTE: Caddy handles HTTP→HTTPS redirect automatically for all sites.
# =========================================================================
classcheck.site {
    encode gzip zstd

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    reverse_proxy host.docker.internal:{$CLASSCHECK_PORT:3001}
}
