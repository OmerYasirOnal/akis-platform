# =============================================================================
# AKIS Platform - Staging Environment Configuration Template
# =============================================================================
# Copy to .env on OCI VM and fill in actual values
# File permissions: chmod 600 .env
# =============================================================================
#
# PROMOTION TO PRODUCTION:
# - Change domains to akisflow.com (no staging prefix)
# - AUTH_COOKIE_SECURE=true (mandatory)
# - Separate OAuth credentials (never reuse staging)
# - LOG_LEVEL=info
# - Stricter RATE_LIMIT_MAX=100
# =============================================================================

# -----------------------------------------------------------------------------
# Core Configuration
# -----------------------------------------------------------------------------
NODE_ENV=production

# Build version (set by CI/CD)
BACKEND_VERSION=staging

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
POSTGRES_USER=akis
POSTGRES_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
POSTGRES_DB=akis_staging
DATABASE_URL=postgresql://akis:REPLACE_WITH_SECURE_PASSWORD@db:5432/akis_staging

# -----------------------------------------------------------------------------
# Authentication & Session
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_JWT_SECRET=REPLACE_WITH_256_BIT_SECRET

# Cookie settings (HTTPS required for secure=true)
AUTH_COOKIE_NAME=akis_session
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_MAXAGE=604800

# -----------------------------------------------------------------------------
# URLs (Critical for OAuth redirects and CORS)
# -----------------------------------------------------------------------------
BACKEND_URL=https://staging.akisflow.com
FRONTEND_URL=https://staging.akisflow.com
CORS_ORIGINS=https://staging.akisflow.com

# -----------------------------------------------------------------------------
# Rate Limiting (Relaxed for staging)
# -----------------------------------------------------------------------------
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW=60000

# Logging (debug for staging, info for production)
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Email Configuration
# -----------------------------------------------------------------------------
# Use mock for staging demos, resend for production-like testing
EMAIL_PROVIDER=mock
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=15

# Uncomment for production email:
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxxx
# RESEND_FROM_EMAIL=noreply@akisflow.com

# -----------------------------------------------------------------------------
# AI Service (Optional)
# -----------------------------------------------------------------------------
# Default to mock AI for cost-free staging
AI_PROVIDER=mock

# Uncomment for real AI:
# AI_PROVIDER=openrouter
# AI_API_KEY=sk-or-v1-xxxxx
# AI_MODEL_DEFAULT=meta-llama/llama-3.3-70b-instruct:free

# Encryption key for per-user AI keys (base64 encoded 32 bytes)
# Generate with: openssl rand -base64 32
AI_KEY_ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTES
AI_KEY_ENCRYPTION_KEY_VERSION=v1

# -----------------------------------------------------------------------------
# OAuth Configuration (Optional - Can run without for staging demos)
# -----------------------------------------------------------------------------
# Create staging-specific OAuth apps in each provider console

# GitHub OAuth (for "Continue with GitHub" login)
# GITHUB_OAUTH_CLIENT_ID=Iv1.xxxxx
# GITHUB_OAUTH_CLIENT_SECRET=xxxxx

# Google OAuth (for "Continue with Google" login)
# GOOGLE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxx

# Atlassian OAuth (for Jira/Confluence connect)
# ATLASSIAN_OAUTH_CLIENT_ID=xxxxx
# ATLASSIAN_OAUTH_CLIENT_SECRET=xxxxx

# Callback URLs are automatically derived from BACKEND_URL:
# - GitHub: ${BACKEND_URL}/auth/oauth/github/callback
# - Google: ${BACKEND_URL}/auth/oauth/google/callback
# - Atlassian: ${BACKEND_URL}/auth/oauth/atlassian/callback

# -----------------------------------------------------------------------------
# MCP Gateway (REQUIRED — always-on in staging for Scribe/Trace/Proto agents)
# -----------------------------------------------------------------------------
# The MCP gateway runs as part of the default docker-compose stack.
# Backend reads GITHUB_MCP_BASE_URL to reach the gateway container.
# Gateway reads GITHUB_TOKEN to authenticate with GitHub API.
#
# GITHUB_TOKEN requirements:
#   - Type: Fine-grained PAT or Classic PAT
#   - Scopes: repo, read:org (minimum for Scribe/Trace/Proto)
#   - Create at: https://github.com/settings/tokens
#   - Rotation: rotate every 90 days; update this file + restart gateway
#
# Verification: /ready endpoint shows mcp.configured=true, mcp.github=true
GITHUB_MCP_BASE_URL=http://mcp-gateway:4010/mcp
GITHUB_TOKEN=REPLACE_WITH_GITHUB_PAT

MCP_ATLASSIAN_ENABLED=false
# ATLASSIAN_MCP_BASE_URL=http://mcp-gateway:4010/mcp/atlassian

# -----------------------------------------------------------------------------
# GitHub Container Registry (for pulling images)
# -----------------------------------------------------------------------------
GITHUB_REPOSITORY=OmerYasirOnal/akis-platform-devolopment

# -----------------------------------------------------------------------------
# Slack Integration (Smart Automations — Optional)
# -----------------------------------------------------------------------------
# SLACK_BOT_TOKEN=xoxb-xxxxx
# SLACK_DEFAULT_CHANNEL=C0123456789

# -----------------------------------------------------------------------------
# Stripe Billing (Optional — Not needed for MVP staging)
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_test_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx
# STRIPE_PRICE_PRO=price_xxxxx
# STRIPE_PRICE_PRO_PLUS=price_xxxxx
# STRIPE_PRICE_TEAM=price_xxxxx

# -----------------------------------------------------------------------------
# Reverse Proxy & Feature Flags
# -----------------------------------------------------------------------------
# Set to true when behind Caddy/nginx (required for secure cookies + IP logging)
TRUST_PROXY=true

# Enable unstable/experimental API routes (default: false)
FEATURE_FLAG_UNSTABLE_ROUTES=false

# -----------------------------------------------------------------------------
# Co-hosted Services (classcheck.site, unisum, etc.)
# -----------------------------------------------------------------------------
# Co-hosted services are managed on the VM via docker-compose.override.yml
# and caddy-sites/*.caddy. No env vars needed in this file for them.
# See docs/deploy/OCI_STAGING_RUNBOOK.md for co-hosting setup.

# -----------------------------------------------------------------------------
# TLS/SSL (Handled by Caddy)
# -----------------------------------------------------------------------------
# Email for Let's Encrypt certificate notifications
ACME_EMAIL=admin@akisflow.com
