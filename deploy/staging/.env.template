# ============================================================
# AKIS Platform — Staging VM Environment File
# Location: /opt/akis/.env
# Last updated: 2026-02-09
# ============================================================
# INSTRUCTIONS:
# 1. Copy this file to /opt/akis/.env on the staging VM
# 2. Replace all <REQUIRED: ...> placeholders with actual values
# 3. Run: docker compose up -d --force-recreate
# 4. Verify: curl https://staging.akisflow.com/health
# ============================================================

# --- Application ---
NODE_ENV=production
PORT=3000
AKIS_HOST=0.0.0.0
BACKEND_URL=https://staging.akisflow.com
FRONTEND_URL=https://staging.akisflow.com
CORS_ORIGINS=https://staging.akisflow.com
LOG_LEVEL=info
TRUST_PROXY=true
CSRF_ENABLED=false

# --- Database ---
POSTGRES_USER=akis
POSTGRES_PASSWORD=<REQUIRED: secure password — generate with: openssl rand -hex 16>
POSTGRES_DB=akis_staging
DATABASE_URL=postgresql://akis:<SAME_PASSWORD_AS_ABOVE>@db:5432/akis_staging

# --- Authentication & Session ---
AUTH_JWT_SECRET=<REQUIRED: generate with: openssl rand -hex 32>
AUTH_COOKIE_NAME=akis_sid
AUTH_COOKIE_MAXAGE=604800
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=Lax
# AUTH_COOKIE_DOMAIN= (leave empty — critical decision, do not set)

# --- OAuth: GitHub ---
GITHUB_OAUTH_CLIENT_ID=v23litstsnDVdFu9kaM
GITHUB_OAUTH_CLIENT_SECRET=557986ca4ccb2418bf8db208e717925454998f71
GITHUB_OAUTH_CALLBACK_URL=http://localhost:3000/auth/oauth/github/callback


# --- OAuth: Google ---
