# Docker Full Stack - Environment Overrides
# Copy to .env.docker and adjust as needed.
# docker compose -f docker-compose.fullstack.yml will load this when present.
#
# Most values are set in docker-compose.fullstack.yml.
# Use .env.docker only for local overrides (e.g., different ports, secrets).

# Backend
# DATABASE_URL=postgresql://postgres:postgres@db:5432/akis_v2
# AUTH_JWT_SECRET=your-secret-at-least-32-chars

# Frontend proxy target (used by Vite dev server in container)
# VITE_PROXY_TARGET=http://backend:3000

# MCP Gateway - requires .env.mcp.local with GITHUB_TOKEN
# Run with: docker compose -f docker-compose.fullstack.yml --profile mcp up
